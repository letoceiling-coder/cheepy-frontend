<?php

/**
 * Alternative: Category sync = run menu_only parser job.
 * Reuses DatabaseParserService::runMenuOnly() — no duplicate parsing logic.
 *
 * Use this if MenuParser doesn't expose parse() and saves directly to DB.
 * Rename to CategorySyncService.php and replace the main implementation.
 */

namespace App\Services;

use App\Services\DatabaseParserService;

class CategorySyncService
{
    public function __construct(
        protected DatabaseParserService $parserService
    ) {}

    public function sync(): array
    {
        // Run menu_only — uses MenuParser, saves categories to DB
        $this->parserService->runMenuOnly();
        // Counts would require runMenuOnly to return them
        return ['created' => 0, 'updated' => 0, 'synced' => true];
    }
}
