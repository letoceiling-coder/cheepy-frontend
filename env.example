# API base URL (Laravel backend)
VITE_API_URL=https://online-parser.siteaacess.store/api/v1

# Yandex Maps API key (MapSection) — never commit real keys
VITE_YANDEX_API_KEY=

# Reverb WebSocket — required for real-time parser updates
# If not set, polling every 30s is used as fallback.
# Production: port 443 = wss through nginx proxy (must match Laravel .env REVERB_APP_KEY):
VITE_REVERB_APP_ID=parser
VITE_REVERB_APP_KEY=parser-key
VITE_REVERB_HOST=online-parser.siteaacess.store
VITE_REVERB_PORT=443
VITE_REVERB_SCHEME=https

# Local development:
# VITE_REVERB_APP_KEY=parser-key
# VITE_REVERB_HOST=localhost
# VITE_REVERB_PORT=8080
# VITE_REVERB_SCHEME=http
